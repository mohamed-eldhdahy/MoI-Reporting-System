# =========================================================
# 🔐 Azure Authentication (Key Vault Access)
# =========================================================


# =========================================================
# 🌍 Environment Settings
# =========================================================
ENVIRONMENT=development
API_VERSION=v1
DEBUG=True

# =========================================================
# 🗄️ Database Connections (Operations & Analytics)
# =========================================================
# Operations DB (Hot Path - Writes)
# SQLALCHEMY_DATABASE_URI_OPS=Driver={ODBC Driver 18 for SQL Server};Server=tcp:moi-sql-server.database.windows.net,1433;Database=moi-ops;Uid=moi-server-admin;Pwd={kMF8B7b8g$YBPQf3};Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;
# Analytics DB (Cold Path - Reads)
# IMPORTANT: Update database name to match your Analytics Database
# SQLALCHEMY_DATABASE_URI_ANALYTICS=Driver={ODBC Driver 18 for SQL Server};Server=tcp:moi-sql-server.database.windows.net,1433;Database=moi-al;Uid=moi-server-admin;Pwd={kMF8B7b8g$YBPQf3};Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# =========================================================
# 📦 Storage
# =========================================================
# BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=moiblob;AccountKey=cbxFw8c2QHsEXY02pSXIsfEMvl/gf8Z/Rhkl8mmeBPoUl5a8mD6FpfXwoXPr3IU4BQW4qobqTpFN+AStdrUlXg==;EndpointSuffix=core.windows.net
# BLOB_CONTAINER_NAME=report-attachments

# =========================================================
# 🔐 Security
# =========================================================
SECRET_KEY=change_this_to_a_secure_random_string_in_production

# =========================================================
# ⚡ Azure Integration Services (Optional)
# =========================================================
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_ML_ENDPOINT=
AZURE_ML_API_KEY=