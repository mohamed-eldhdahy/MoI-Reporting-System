{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "moi-df"
		},
		"moi_analytics_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'moi_analytics'"
		},
		"moi_operation_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'moi_operation'"
		},
		"moi_operations_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'moi_operations'"
		},
		"moi_analytics_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "moi-sql-server.database.windows.net"
		},
		"moi_analytics_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "moi-al"
		},
		"moi_analytics_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "moi-server-admin"
		},
		"moi_operation_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "moi-sql-server.database.windows.net"
		},
		"moi_operation_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "moi-ops"
		},
		"moi_operation_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "moi-server-admin"
		},
		"moi_operations_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "moi-server.database.windows.net"
		},
		"moi_operations_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "moi-database"
		},
		"moi_operations_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "moi-server-admin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "moi-df_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"moi_analytics_password": {
						"value": "[parameters('moi_analytics_password')]"
					},
					"moi_operation_password": {
						"value": "[parameters('moi_operation_password')]"
					},
					"moi_operations_password": {
						"value": "[parameters('moi_operations_password')]"
					},
					"moi_analytics_properties_typeProperties_server": {
						"value": "[parameters('moi_analytics_properties_typeProperties_server')]"
					},
					"moi_analytics_properties_typeProperties_database": {
						"value": "[parameters('moi_analytics_properties_typeProperties_database')]"
					},
					"moi_analytics_properties_typeProperties_userName": {
						"value": "[parameters('moi_analytics_properties_typeProperties_userName')]"
					},
					"moi_operation_properties_typeProperties_server": {
						"value": "[parameters('moi_operation_properties_typeProperties_server')]"
					},
					"moi_operation_properties_typeProperties_database": {
						"value": "[parameters('moi_operation_properties_typeProperties_database')]"
					},
					"moi_operation_properties_typeProperties_userName": {
						"value": "[parameters('moi_operation_properties_typeProperties_userName')]"
					},
					"moi_operations_properties_typeProperties_server": {
						"value": "[parameters('moi_operations_properties_typeProperties_server')]"
					},
					"moi_operations_properties_typeProperties_database": {
						"value": "[parameters('moi_operations_properties_typeProperties_database')]"
					},
					"moi_operations_properties_typeProperties_userName": {
						"value": "[parameters('moi_operations_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}